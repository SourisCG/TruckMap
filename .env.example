# Clave publica para mosaicos. Restrinjala al dominio de Vercel en TomTom.
NEXT_PUBLIC_TOMTOM_API_KEY=

# Clave privada usada por las rutas API del servidor.
TOMTOM_API_KEY=

# Envio de sugerencias. El remitente debe pertenecer a un dominio verificado.
RESEND_API_KEY=
SUGGESTIONS_FROM_EMAIL=TruckMap <reportes@tu-dominio.mx>
SUGGESTIONS_TO_EMAIL=

# Proteccion opcional del formulario con Cloudflare Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Limites distribuidos opcionales. Sin estos valores se usa memoria local.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
